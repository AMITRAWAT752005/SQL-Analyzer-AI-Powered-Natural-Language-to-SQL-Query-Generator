generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH
}

enum ConnectionType {
  POSTGRESQL
  MYSQL
  SQLITE
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum QueryStatus {
  SUCCESS
  FAILED
  RUNNING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String?   @unique
  passwordHash    String
  fullName        String?
  avatarUrl       String?
  role            UserRole  @default(USER)
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  databaseConnections     DatabaseConnection[]
  preferences             UserPreference?
  queryHistory            QueryHistory[]
  aiRequestLogs           AIRequestLog[]
  auditLogs               AuditLog[]

  @@index([email])
  @@index([isActive])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DatabaseConnection {
  id              String           @id @default(uuid())
  name            String
  connectionType  ConnectionType   @default(POSTGRESQL)
  host            String
  port            Int
  databaseName    String
  username        String
  password        String
  sslMode         String?          @default("prefer")
  status          ConnectionStatus @default(DISCONNECTED)
  lastConnectedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([status])
  @@index([connectionType])
}

model UserPreference {
  id             String   @id @default(uuid())
  theme          String   @default("system")
  language       String   @default("en")
  timezone       String   @default("UTC")
  resultsPerPage Int      @default(20)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model QueryHistory {
  id            String      @id @default(uuid())
  prompt        String
  sqlQuery      String?
  resultSummary String?
  status        QueryStatus @default(SUCCESS)
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AIRequestLog {
  id           String   @id @default(uuid())
  provider     String
  model        String
  requestBody  String
  responseBody String?
  statusCode   Int?
  durationMs   Int?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
